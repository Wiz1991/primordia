{
    "url_base": "/",
    "port": "8282",
    "log_level": "info",
    "debrids": [
      {
        "name": "realdebrid",
        "api_key": "${REALDEBRID_API_KEY}",
        "download_api_keys": [
          "${REALDEBRID_DOWNLOAD_API_KEY}"
        ],
        "folder": "/mnt/remote/realdebrid/__all__",
        "rate_limit": "250/minute",
        "minimum_free_slot": 1,
        "use_webdav": true,
        "torrents_refresh_interval": "15s",
        "download_links_refresh_interval": "40m",
        "workers": 600,
        "auto_expire_links_after": "3d",
        "folder_naming": "original_no_ext"
      }
    ],
    "qbittorrent": {
      "download_folder": "/mnt/symlinks",
      "refresh_interval": 15
    },
    "repair": {
      "interval": "6h",
      "auto_process": true,
      "use_webdav": true,
      "workers": 1,
      "strategy": "per_torrent"
    },
    "webdav": {},
    "rclone": {
      "enabled": true,
      "mount_path": "/mnt/remote",
      "rc_port": "5572",
      "vfs_cache_mode": "full",
      "vfs_cache_max_age": "1h",
      "vfs_cache_poll_interval": "1m",
      "vfs_read_chunk_size": "128M",
      "vfs_read_chunk_size_limit": "off",
      "vfs_read_ahead": "128k",
      "async_read": false,
      "transfers": 4,
      "uid": 1000,
      "gid": 1000,
      "attr_timeout": "1s",
      "dir_cache_time": "5m",
      "log_level": "INFO"
    },
    "allowed_file_types": [
      "3gp", "ac3", "aiff", "alac", "amr", "ape", "asf", "asx", "avc", "avi",
      "bin", "bivx", "dat", "divx", "dts", "dv", "dvr-ms", "flac", "fli", "flv",
      "ifo", "m2ts", "m2v", "m3u", "m4a", "m4p", "m4v", "mid", "midi", "mk3d",
      "mka", "mkv", "mov", "mp2", "mp3", "mp4", "mpa", "mpeg", "mpg", "nrg",
      "nsv", "nuv", "ogg", "ogm", "ogv", "pva", "qt", "ra", "rm", "rmvb",
      "strm", "svq3", "ts", "ty", "viv", "vob", "voc", "vp3", "wav", "webm",
      "wma", "wmv", "wpl", "wtv", "wv", "xvid"
    ]
  }