APPDATA_DIR=/srv/homelab
PUID=1000
PGID=1000
TZ=Europe/Paris
LOG_LEVEL=info

DOMAIN_NAME=example.com
ACME_EMAIL=admin@example.com
CF_DNS_API_TOKEN=your-cloudflare-api-token
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token
POSTGRES_PASSWORD=your-postgres-password

TAILSCALE_IP=100.x.x.x

GRAFANA_ANONYMOUS_ACCESS=false

# *arr API keys (for Exportarr metrics)
SONARR_API_KEY=your-sonarr-api-key
RADARR_API_KEY=your-radarr-api-key
PROWLARR_API_KEY=your-prowlarr-api-key
BAZARR_API_KEY=your-bazarr-api-key

# Restic backup to Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
RESTIC_PASSWORD=your-restic-repo-password
